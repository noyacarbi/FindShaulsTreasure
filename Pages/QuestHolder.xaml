<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:modules="clr-namespace:FindShaulsTreasure.Quests"
             x:Class="FindShaulsTreasure.Pages.QuestHolder"
             Title="QuestHolder">
    <Grid RowDefinitions="auto, *, auto" RowSpacing="7.5" Padding="7.5">

        <Grid ColumnDefinitions="*, *" Grid.Row="0" ColumnSpacing="7.5">
            <Label x:Name="lQuestName" Text="Quest X" FontSize="Small"  HorizontalOptions="Center" Grid.Column="0"/>
            <Label x:Name="lScore" Text="Score: X" FontSize="Small" HorizontalOptions="Center" Grid.Column="1"/>

            <Button Opacity="0" HorizontalOptions="Fill" VerticalOptions="Fill" Grid.Column="0" Pressed="OnSecret_Pressed" Released="OnSecret_Released"/>
        </Grid>

        <ContentView x:Name="cvCurrentQuest" Grid.Row="1"/>

        <Grid Grid.Row="2">
            <Grid x:Name="gManual" ColumnDefinitions="2.5*, *" ColumnSpacing="7.5" IsVisible="False">
                <Entry x:Name="eAnswer" Placeholder="Answer" Grid.Column="0" />
                <Button Text="Submit" Grid.Column="1" Clicked="bSubmit_Clicked"/>
            </Grid>

            <Grid x:Name="gAuto" IsVisible="False">
                <Button Text="Continue" HorizontalOptions="Fill" Clicked="bSubmit_Clicked"/>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>